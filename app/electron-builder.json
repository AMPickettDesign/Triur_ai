{
  "appId": "com.ampickettdesign.triur",
  "productName": "Triur.ai",
  "copyright": "Copyright © 2026 Ashley Pickett",
  "directories": {
    "output": "../dist"
  },
  "files": [
    "**/*",
    "!node_modules/.cache",
    "!**/*.map"
  ],
  "extraResources": [
    {
      "from": "../dist/triur-brain",
      "to": "triur-brain",
      "filter": ["**/*"]
    },
    {
      "from": "../config",
      "to": "config",
      "filter": ["**/*"]
    }
  ],
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ],
    "icon": "assets/icon.ico"
  },
  "mac": {
    "target": [
      {
        "target": "dmg",
        "arch": ["x64", "arm64"]
      }
    ],
    "icon": "assets/icon.png",
    "category": "public.app-category.productivity"
  },
  "nsis": {
    "oneClick": true,
    "allowToChangeInstallationDirectory": false,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "Triur.ai"
  },
  "dmg": {
    "title": "Install Triur.ai",
    "background": null,
    "window": {
      "width": 540,
      "height": 380
    }
  }
}
